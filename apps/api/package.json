    "@lifeos/shared": "workspace:*",
    "hono": "^4.5.0",
    "jose": "^5.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.140",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.23.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
